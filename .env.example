# =============================================================================
# ZUMBO STORE — Variáveis de Ambiente
# Copie este ficheiro para .env.local e preencha os valores.
# NUNCA commite o .env.local no git.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# --- Aplicação ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Zumbo Store

# --- Logs (debug | info | warn | error) ---
LOG_LEVEL=info

# --- Pagamentos: M-Pesa ---
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_BASE_URL=https://api.sandbox.vm.co.mz

# --- Pagamentos: e-Mola ---
EMOLA_API_KEY=
EMOLA_BASE_URL=

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@zumbostore.co.mz
SENDGRID_FROM_NAME=Zumbo Store

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- WhatsApp Business API ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
